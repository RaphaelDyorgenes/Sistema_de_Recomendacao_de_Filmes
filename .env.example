# ──────────────────────────────────────────────────────────
# .env.example — Variáveis de ambiente do projeto
# Copie este arquivo para .env e ajuste os valores.
# ──────────────────────────────────────────────────────────

# Ambiente de execução: dev | staging | production
ENV=dev

# MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=recsys-movielens

# Dados ───────────────────────────────────────────────────
# Quantidade máxima de interações usadas no pré-processamento.
# Use 0 para processar o dataset completo.
DATA_SAMPLE_SIZE=100000

# Semente global para reprodutibilidade
RANDOM_SEED=42
